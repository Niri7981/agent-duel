generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Round {
  id               String   @id
  status           String
  bankrollPerAgent Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  actions          Action[]
}

model Action {
  id        String   @id
  roundId   String
  agentId   String
  side      String
  sizeUsd   Float
  reason    String
  createdAt DateTime @default(now())
  round     Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
}
